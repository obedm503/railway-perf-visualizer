    "hono": "^4.12.5",
    "nanoid": "^5.1.6",
    "openid-client": "^6.8.2",
    "rivetkit": "^2.1.6"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.9"
  }
