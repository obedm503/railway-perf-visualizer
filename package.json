{
  "name": "railway-perf-visualizer",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/web",
    "apps/api",
    "apps/demo"
  ],
  "scripts": {
    "dev": "bun run --filter '*' --elide-lines 0 dev",
    "dev:web": "bun run --cwd apps/web dev",
    "dev:api": "bun run --cwd apps/api dev",
    "dev:demo": "bun run --cwd apps/demo dev",
    "build": "bun run --cwd apps/web build && bun run --cwd apps/api build && bun run --cwd apps/demo build",
    "start": "bun run --cwd apps/api start",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript": "~5.9.3"
  }
}
